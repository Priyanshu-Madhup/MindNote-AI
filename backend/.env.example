# MindNote AI — Backend Environment Variables
# =============================================
# Copy this file to backend/.env and fill in your values.
# NEVER commit .env to Git (it's in .gitignore).

# ── Neon PostgreSQL ────────────────────────────────────────────────────────────
# Get this from your Neon project dashboard → Connection Details
# IMPORTANT: Use postgresql+asyncpg:// (NOT postgresql://)
DATABASE_URL=postgresql+asyncpg://user:password@ep-xxx-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# ── Groq AI ───────────────────────────────────────────────────────────────────
# Get this from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here
